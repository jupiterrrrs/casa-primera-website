From 75fb1ca4a2d193ae49878c025d93fdc460267823 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Sat, 18 Jul 2026 13:40:28 +0000
Subject: [PATCH] Fix navbar scroll style and mobile amenities carousel
 responsiveness

- Navbar: solid white background on scroll (and when mobile menu is
  open) instead of translucent teal, matching the reference site's
  white nav-on-scroll pattern. Text/icons stay dark and readable
  against it at all times.
- Navbar: logo is now responsively sized (smaller on phones) so it
  no longer overflows/overlaps page content on mobile.
- AmenitiesCarousel: number of visible cards is now responsive
  (1 on phones, 2 on tablets, 3 on desktop) instead of a hardcoded
  3, which was crushing card width on mobile and truncating titles
  and descriptions. Fixed the slide-offset math to match the actual
  card gap, tucked the prev/next arrows onto screen on mobile, and
  let the dot indicators wrap instead of overflow.
---
 src/app/components/AmenitiesCarousel.tsx | 45 ++++++++++++++++++------
 src/app/components/Navbar.tsx            | 20 ++++++-----
 2 files changed, 45 insertions(+), 20 deletions(-)

diff --git a/src/app/components/AmenitiesCarousel.tsx b/src/app/components/AmenitiesCarousel.tsx
index 14be5db..10f4343 100644
--- a/src/app/components/AmenitiesCarousel.tsx
+++ b/src/app/components/AmenitiesCarousel.tsx
@@ -201,12 +201,35 @@ function AmenityLightbox({
   );
 }
 
+function useCardsVisible() {
+  const [cardsVisible, setCardsVisible] = useState(1);
+
+  useEffect(() => {
+    const compute = () => {
+      const w = window.innerWidth;
+      if (w >= 1024) setCardsVisible(3);
+      else if (w >= 640) setCardsVisible(2);
+      else setCardsVisible(1);
+    };
+    compute();
+    window.addEventListener("resize", compute);
+    return () => window.removeEventListener("resize", compute);
+  }, []);
+
+  return cardsVisible;
+}
+
 export function AmenitiesCarousel() {
   const [startIdx, setStartIdx] = useState(0);
   const [lightboxIndex, setLightboxIndex] = useState<number | null>(null);
-  const cardsVisible = 3;
+  const cardsVisible = useCardsVisible();
   const trackRef = useRef<HTMLDivElement>(null);
 
+  // Keep startIdx in range whenever the visible count changes (e.g. rotating a device)
+  useEffect(() => {
+    setStartIdx((i) => Math.min(i, Math.max(0, amenities.length - cardsVisible)));
+  }, [cardsVisible]);
+
   const canPrev = startIdx > 0;
   const canNext = startIdx < amenities.length - cardsVisible;
 
